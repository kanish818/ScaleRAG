# ScaleRAG backend environment

# Primary generation model
GROQ_API_KEY=your_groq_api_key

# Embeddings + fallback generation model
GEMINI_API_KEY=your_gemini_api_key

# Optional cross-encoder reranker
COHERE_API_KEY=your_cohere_api_key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# JWT
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Frontend origin
FRONTEND_URL=http://localhost:5173

# Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_STORAGE_BUCKET=documents

# Database
# Production: Supabase/Postgres connection string with pgvector enabled
# Local fallback: sqlite:///./data/scalerag.db
DATABASE_URL=sqlite:///./data/scalerag.db

# App
MAX_UPLOAD_SIZE_MB=50
TEMP_DIR=./tmp
